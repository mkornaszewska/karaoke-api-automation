{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "@playwright/test"]
  },
  "exclude": ["node_modules", "dist", "playwright-report", "test-results"],
  "include": ["**/*.ts"]
}
